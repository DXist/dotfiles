window-theme = dark
font-family = PragmataPro
font-feature = -dlig
font-size = 14
theme = dark:Solarized Dark Patched,light:Solarized Dark Patched

copy-on-select = clipboard

keybind = super+f=esc:f
keybind = super+b=esc:b
keybind = super+j=esc:j
keybind = super+k=esc:k
keybind = super+shift+j=esc:J
keybind = super+shift+k=esc:K
